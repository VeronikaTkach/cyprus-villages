generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum FestivalCategory {
  WINE
  FOOD
  CULTURAL
  RELIGIOUS
  MUSIC
  ARTS
  SPORT
  OTHER
}

enum FestivalEditionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  CANCELLED
}

enum LocationPointType {
  PARKING
  VENUE
  MEETING_POINT
  WC
  SHUTTLE
  VIEWPOINT
  OTHER
}

// MediaKind describes the presentation role of a media asset, not its file type.
// All values are role-oriented so the purpose of each record is unambiguous.
// MVP1: only image files are supported; kind determines how the image is used.
enum MediaKind {
  GALLERY    // General inline image — gallery, body content, additional photos
  COVER      // Primary hero / cover image for a page or listing
  THUMBNAIL  // Compact preview used in cards or listing views
}

enum UserRole {
  SUPER_ADMIN
  CONTENT_ADMIN
  EDITOR
}

// AuditAction tracks what happened to an entity.
// DELETE is kept intentionally: hard delete is not the primary business path
// (archive/deactivate is preferred), but it can occur for technical or admin
// reasons such as data-entry mistakes or duplicate records.
// Any hard delete must be logged here so the audit trail remains intact.
enum AuditAction {
  CREATE
  UPDATE
  DELETE   // Rare: technical/admin removal only; prefer ARCHIVE for business flows
  PUBLISH
  ARCHIVE
  CANCEL
}

// ─────────────────────────────────────────────────────────────
// VILLAGE
// A long-lived geographic and cultural entity.
// Festivals belong to villages; location points and media can reference villages.
// ─────────────────────────────────────────────────────────────

model Village {
  id          Int     @id @default(autoincrement())
  slug        String  @unique

  // Greek name — displayed permanently alongside the localised name.
  // Kept as a direct column because it is always shown regardless of the
  // active locale (it is the "authentic" village name, not just one translation).
  nameEl      String?

  // Administrative geography
  district    String?
  region      String?

  // Base geographic center of the village
  centerLat   Float?
  centerLng   Float?

  // Visibility / lifecycle
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  translations   VillageTranslation[]
  festivals      Festival[]
  locationPoints LocationPoint[]
  media          Media[]

  @@index([isActive])
  @@index([district])
  @@index([region])
}

// One row per locale per village.
// Adding a new language never requires a schema migration — just add rows.
model VillageTranslation {
  id          Int     @id @default(autoincrement())
  villageId   Int
  locale      String  // 'en' | 'ru' | 'el' | any future locale
  name        String
  description String? @db.Text

  village     Village @relation(fields: [villageId], references: [id], onDelete: Cascade)

  @@unique([villageId, locale])
  @@index([villageId])
  @@index([locale])
}

// ─────────────────────────────────────────────────────────────
// FESTIVAL
// The recurring festival concept/brand, not a single event.
// One Festival can have many FestivalEditions (one per year).
// ─────────────────────────────────────────────────────────────

model Festival {
  id        Int              @id @default(autoincrement())
  slug      String           @unique
  villageId Int

  // Multilingual titles
  titleEn   String
  titleRu   String?
  titleEl   String?

  // Multilingual short descriptions
  shortDescriptionEn String? @db.Text
  shortDescriptionRu String? @db.Text
  shortDescriptionEl String? @db.Text

  category  FestivalCategory @default(OTHER)

  // Visibility / lifecycle
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  village  Village          @relation(fields: [villageId], references: [id])
  editions FestivalEdition[]
  media    Media[]

  @@index([villageId])
  @@index([isActive])
  @@index([category])
}

// ─────────────────────────────────────────────────────────────
// FESTIVAL EDITION
// A concrete yearly instance of a Festival.
// This is the central scheduling and publishing entity.
// ─────────────────────────────────────────────────────────────

model FestivalEdition {
  id         Int    @id @default(autoincrement())
  festivalId Int
  year       Int

  // Dates — nullable when isDateTba is true
  startDate  DateTime?
  endDate    DateTime?
  isDateTba  Boolean   @default(false)

  // Times stored as "HH:mm" strings (e.g. "18:00").
  // Intentional MVP1 simplification: Cyprus festivals are local-time events.
  // All times are assumed to be Cyprus local time (EET/EEST, UTC+2/+3).
  // No UTC conversion is needed at this stage — times are display-only.
  // If cross-timezone scheduling is ever required, add a timestamptz field then.
  startTime  String?
  endTime    String?

  // Publication lifecycle
  status      FestivalEditionStatus @default(DRAFT)
  publishedAt DateTime?
  lastVerifiedAt DateTime?

  // Primary venue — denormalised for quick access
  // Additional points live in LocationPoint
  venueName   String?
  venueLat    Float?
  venueLng    Float?

  // Primary parking — denormalised for quick access
  parkingName String?
  parkingLat  Float?
  parkingLng  Float?

  // Source tracking
  officialUrl String?
  sourceUrl   String?
  sourceNote  String? @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  festival       Festival        @relation(fields: [festivalId], references: [id])
  locationPoints LocationPoint[]
  media          Media[]

  // Each festival can have at most one edition per year
  @@unique([festivalId, year])

  @@index([festivalId])
  @@index([status])
  @@index([year])
  @@index([startDate])
}

// ─────────────────────────────────────────────────────────────
// LOCATION POINT
// A geographic point of interest. Both foreign keys are optional and
// independently nullable — this is intentional. Three valid ownership states:
//
//   villageId only       — permanent village landmark (viewpoint, WC, etc.)
//                          visible on the village page and map at all times.
//
//   festivalEditionId only — temporary point specific to one festival edition
//                            (temporary stage, shuttle stop, event-only parking).
//
//   both set             — a permanent village point that also serves as a
//                          festival edition point (e.g. the village car park
//                          repurposed as festival parking). Appears on both the
//                          village map and the edition detail page.
//
// An orphan row (both null) should not exist; enforce at service level.
// ─────────────────────────────────────────────────────────────

model LocationPoint {
  id                Int               @id @default(autoincrement())
  type              LocationPointType
  label             String

  lat               Float
  lng               Float

  note              String?

  villageId         Int?
  festivalEditionId Int?

  isActive          Boolean  @default(true)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  village         Village?         @relation(fields: [villageId], references: [id])
  festivalEdition FestivalEdition? @relation(fields: [festivalEditionId], references: [id])

  @@index([villageId])
  @@index([festivalEditionId])
  @@index([type])
  @@index([isActive])
}

// ─────────────────────────────────────────────────────────────
// MEDIA
// Uploaded image metadata. Three nullable foreign keys allow attaching a media
// record to any entity type without a separate join table per entity.
//
// OWNERSHIP INVARIANT (enforced at service layer):
//   Each Media row must have exactly one FK set — it belongs to exactly one
//   parent: a Village, a Festival, or a FestivalEdition.
//   Having zero or more than one FK set is invalid and must be rejected by the
//   service before writing. Prisma cannot express this as a DB-level constraint;
//   it is a service-level rule. See docs/architecture.md § Schema design decisions.
//
//   Rationale: media assets are not shared or reused across entities in MVP1.
//   If asset reuse becomes a requirement, a many-to-many join table is the
//   correct solution — not relaxing the single-owner rule.
// ─────────────────────────────────────────────────────────────

model Media {
  id     Int       @id @default(autoincrement())
  url    String
  alt    String?
  width  Int?
  height Int?
  kind   MediaKind @default(GALLERY)

  // Exactly one of these must be non-null — see ownership invariant above
  villageId         Int?
  festivalId        Int?
  festivalEditionId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  village         Village?         @relation(fields: [villageId], references: [id])
  festival        Festival?        @relation(fields: [festivalId], references: [id])
  festivalEdition FestivalEdition? @relation(fields: [festivalEditionId], references: [id])

  @@index([villageId])
  @@index([festivalId])
  @@index([festivalEditionId])
  @@index([kind])
}

// ─────────────────────────────────────────────────────────────
// USER
// Minimal admin user — present for AuditLog relations.
// Auth fields (passwordHash, tokens) are added when auth is implemented.
// ─────────────────────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  role      UserRole @default(EDITOR)
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  auditLogs AuditLog[]

  @@index([role])
  @@index([isActive])
}

// ─────────────────────────────────────────────────────────────
// AUDIT LOG
// Immutable record of admin actions on any entity.
// beforeJson / afterJson capture state snapshots for rollback/review.
// userId is nullable to support future system-initiated actions.
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id         Int         @id @default(autoincrement())
  entityType String      // e.g. "Village", "Festival", "FestivalEdition"
  entityId   Int
  action     AuditAction
  beforeJson Json?
  afterJson  Json?

  // Nullable: system-initiated actions may not have a user
  userId     Int?
  user       User?       @relation(fields: [userId], references: [id])

  createdAt  DateTime    @default(now())
  // No updatedAt — audit logs are immutable

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([action])
}
