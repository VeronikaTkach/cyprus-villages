# API service environment variables
# Copy to api.env and fill in values

NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cyprus_villages

JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3000

# Cloudflare R2 (optional — media upload disabled if empty)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=https://media.example.com
